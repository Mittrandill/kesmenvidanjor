# İletişim formu e-posta gönderimi (Resend) — opsiyonel.
# Tanımlı değilse form çalışır ama mail göndermez (talep sunucu loguna düşer).
# https://resend.com → API Keys
RESEND_API_KEY=

# Gönderen adres. Resend'de domain doğrulanınca: "Kesmen Vidanjör <info@cesmekesmenvidanjor.com>"
# Doğrulama yapılmadıysa test için "onboarding@resend.dev" kullanılır.
CONTACT_FROM="Kesmen Vidanjör <onboarding@resend.dev>"

# Supabase — admin panel (/admin) auth + veritabanı. Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
